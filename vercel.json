{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/app", "destination": "/index.html" }
  ],
  "functions": {
    "api/search.js":    { "memory": 256, "maxDuration": 30 },
    "api/assistant.js": { "memory": 256, "maxDuration": 30 },
    "api/usage.js":     { "memory": 128, "maxDuration": 10 },
    "api/checkout.js":  { "memory": 128, "maxDuration": 15 },
    "api/webhook.js":   { "memory": 128, "maxDuration": 30 },
    "api/confirm.js":   { "memory": 128, "maxDuration": 15 },
    "api/lexicon.js":   { "memory": 512, "maxDuration": 10 },
    "api/admin.js":     { "memory": 256, "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
